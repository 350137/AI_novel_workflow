{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditReport",
  "description": "Auditor 产出的审计报告。40维三层审计结果 + 路由推荐 + 备忘偏离分析。",
  "type": "object",
  "required": ["chapter", "timestamp", "overallScore", "verdict", "issues", "layerScores", "routeRecommendation", "memoDrift", "hookStatus"],
  "properties": {
    "chapter": { "type": "integer" },
    "timestamp": { "type": "string", "format": "date-time" },
    "overallScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "0.15 × scriptHealth + 0.20 × hybridScore + 0.65 × llmScore"
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"],
      "description": "PASS=≥90无CRITICAL / PASS_WITH_WARNINGS=≥70 / FAIL=<70或有CRITICAL"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "dimension", "category", "severity", "location", "description", "suggestion"],
        "properties": {
          "id": { "type": "string", "description": "ISS-N-XXX 格式" },
          "dimension": { "type": "string", "description": "40维名称" },
          "category": {
            "type": "string",
            "enum": ["LOCAL", "STRUCTURAL", "CRITICAL"]
          },
          "severity": {
            "type": "string",
            "enum": ["INFO", "WARNING", "HIGH", "CRITICAL"]
          },
          "layer": {
            "type": "integer",
            "enum": [1, 2, 3]
          },
          "location": {
            "type": "string",
            "description": "正文中的问题位置（段落号/句子引用）"
          },
          "description": { "type": "string" },
          "evidence": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "layerScores": {
      "type": "object",
      "required": ["scriptHealth", "hybridScore", "llmScore"],
      "properties": {
        "scriptHealth": { "type": "number" },
        "hybridScore": { "type": "number" },
        "llmScore": { "type": "number" }
      }
    },
    "routeRecommendation": {
      "type": "string",
      "enum": ["POLISH", "LOCAL_PATCH", "STRUCTURAL_REWRITE", "HUMAN_ESCALATE"],
      "description": "推荐路由——由 Orchestrator 的 Gate 逻辑做最终决策"
    },
    "memoDrift": {
      "type": "object",
      "properties": {
        "drift_detected": { "type": "boolean" },
        "drift_details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section": { "type": "string" },
              "expected": { "type": "string" },
              "actual": { "type": "string" },
              "severity": { "type": "string" }
            }
          }
        }
      }
    },
    "hookStatus": {
      "type": "object",
      "properties": {
        "overdueHooks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "newPlants": { "type": "integer" },
        "resolutions": { "type": "integer" },
        "openVsResolvedRatio": { "type": "number" },
        "budgetUsage": {
          "type": "object",
          "properties": {
            "active": { "type": "integer" },
            "max": { "type": "integer" }
          }
        }
      }
    },
    "continuityConcerns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "auditorNotes": {
      "type": "string",
      "description": "Auditor 的自由文本注释"
    }
  }
}
